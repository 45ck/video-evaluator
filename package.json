{
  "name": "@45ck/video-evaluator",
  "version": "0.1.1",
  "description": "Shared video evaluation and understanding skill pack for coding-agent workflows",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "video-evaluator-agent": "agent/run-tool.mjs"
  },
  "files": [
    "dist/**",
    "agent/**",
    "skills/**",
    "docs/**",
    "assets/**",
    "benchmarks/**",
    "eng.traineddata",
    "README.md",
    "SUPPORT.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "skill-catalog": "node --import tsx scripts/harness/skill-catalog.ts",
    "install-skill-pack": "node --import tsx scripts/harness/install-skill-pack.ts",
    "video-intake": "node --import tsx scripts/harness/video-intake.ts",
    "video-shots": "node --import tsx scripts/harness/video-shots.ts",
    "segment-evidence": "node --import tsx scripts/harness/segment-evidence.ts",
    "segment-storyboard": "node --import tsx scripts/harness/segment-storyboard.ts",
    "storyboard-extract": "node --import tsx scripts/harness/storyboard-extract.ts",
    "storyboard-ocr": "node --import tsx scripts/harness/storyboard-ocr.ts",
    "storyboard-understand": "node --import tsx scripts/harness/storyboard-understand.ts",
    "storyboard-transitions": "node --import tsx scripts/harness/storyboard-transitions.ts",
    "review-bundle": "node --import tsx scripts/harness/review-bundle.ts",
    "compare-bundles": "node --import tsx scripts/harness/compare-bundles.ts",
    "package-review-prompt": "node --import tsx scripts/harness/package-review-prompt.ts",
    "benchmark:youtube": "node --import tsx scripts/bench/youtube-diverse-benchmark.ts"
  },
  "dependencies": {
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/45ck/video-evaluator.git"
  },
  "homepage": "https://github.com/45ck/video-evaluator",
  "bugs": {
    "url": "https://github.com/45ck/video-evaluator/issues"
  },
  "keywords": [
    "video",
    "evaluation",
    "storyboard",
    "review",
    "artifact-bundle",
    "benchmarking",
    "codex",
    "claude-code",
    "ocr",
    "skills",
    "video-analysis",
    "agent-runtime"
  ],
  "packageManager": "npm@10.8.2"
}
